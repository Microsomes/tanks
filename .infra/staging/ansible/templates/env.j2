{% set host = app_domain if app_domain else ansible_host %}
{% set scheme = 'https' if ssl_enabled else 'http' %}
APP_NAME={{ app_name }}
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL={{ scheme }}://{{ host }}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE={{ db_name }}
DB_USERNAME={{ db_user }}
DB_PASSWORD={{ db_password }}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT={{ 'true' if ssl_enabled else 'false' }}
SESSION_PATH=/
SESSION_DOMAIN={{ host }}

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD={{ redis_password | default('null', true) }}
REDIS_PORT=6379

MAIL_MAILER={{ mail_mailer }}
MAIL_SCHEME=null
MAIL_HOST={{ mail_host }}
MAIL_PORT={{ mail_port }}
MAIL_USERNAME={{ mail_username }}
MAIL_PASSWORD={{ mail_password }}
MAIL_FROM_ADDRESS="{{ mail_from_address }}"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID={{ reverb_app_id }}
REVERB_APP_KEY={{ reverb_app_key }}
REVERB_APP_SECRET={{ reverb_app_secret }}
REVERB_HOST=127.0.0.1
REVERB_PORT={{ reverb_port }}
REVERB_SCHEME=http

VITE_APP_NAME={{ app_name }}
VITE_REVERB_APP_KEY={{ reverb_app_key }}
VITE_REVERB_HOST={{ host }}
VITE_REVERB_PORT={{ '443' if ssl_enabled else '80' }}
VITE_REVERB_SCHEME={{ scheme }}

TELESCOPE_ENABLED=false
